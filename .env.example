# ── Telegram ────────────────────────────────────────────────────────────────
# From @BotFather (/newbot). Looks like 123456789:AAH...long-string...
TELEGRAM_TOKEN=
# Your numeric chat id (message @userinfobot to get it).
TELEGRAM_CHAT_ID=

# ── Clinic page ──────────────────────────────────────────────────────────────
# The Terminland deeplink you open to book.
CLINIC_URL=https://www.terminland.de/noris-psychotherapie/online/ADHS_new/
# If this text shows on the schedule step, there are no slots (German site).
NO_SLOTS_TEXT=keine freien Termine

# ── Schedule ─────────────────────────────────────────────────────────────────
# Only check inside this local window (HH:MM, 24h).
WINDOW_START=08:00
WINDOW_END=21:00
# Minutes between checks (loop mode only; GitHub Actions uses its own cron).
INTERVAL_MINUTES=15
# IANA timezone for the window. The clinic is in Bavaria → Europe/Berlin.
# Leave blank to use the host's local timezone.
MONITOR_TZ=Europe/Berlin

# ── Browser / misc ───────────────────────────────────────────────────────────
HEADLESS=true
NAV_TIMEOUT_MS=30000
# Where to persist "already notified" slot ids between runs.
STATE_PATH=state.json
# Where to save page HTML + screenshot when a check is not clearly empty
# (i.e. slots available, or an unrecognised page) — useful ground truth.
CAPTURE_DIR=captures
